generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum HomeworkStatus {
  ACCEPTED
  REJECTED
  PENDING
  CHECKED
}

model User {
  id              Int              @id @default(autoincrement())
  first_name      String
  last_name       String
  password        String
  role            Role
  phone           String           @unique
  email           String           @unique
  address         String
  status          Status           @default(active)
  created_at      DateTime         @default(now())
  update_at       DateTime         @default(now())
  photo           String?
  attendances     Attendance[]
  homework        Homework[]
  homeworkResults HomeworkResult[]
  lessons         Lesson[]
}

model Student {
  id                     Int                     @id @default(autoincrement())
  password               String
  phone                  String                  @unique
  email                  String                  @unique
  birth_date             DateTime
  address                String
  status                 StudentStatus           @default(active)
  created_at             DateTime                @default(now())
  update_at              DateTime                @default(now())
  photo                  String?
  full_name              String
  attendances            Attendance[]
  homeworkAnswerStudents HomeworkAnswerStudent[]
  studentGroups          StudentGroup[]
}

model Teacher {
  id              Int              @id @default(autoincrement())
  password        String
  phone           String           @unique
  email           String           @unique
  address         String
  status          Status           @default(active)
  created_at      DateTime         @default(now())
  update_at       DateTime         @default(now())
  photo           String?
  full_name       String
  attendances     Attendance[]
  GroupTeacher    GroupTeacher[]
  homework        Homework[]
  homeworkResults HomeworkResult[]
  lessons         Lesson[]
}

model Course {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  description    String?
  price          Decimal
  created_at     DateTime @default(now())
  update_at      DateTime @default(now())
  duration_hours Int
  duration_month Int
  status         Status   @default(active)
  groups         Group[]
}

model Room {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  update_at  DateTime @default(now())
  status     Status   @default(active)
  capacity   Int
  groups     Group[]
}

model Group {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  description     String?
  course_id       Int
  room_id         Int
  start_date      DateTime
  start_time      String
  max_student     Int
  status          GroupStatus      @default(active)
  created_at      DateTime         @default(now())
  update_at       DateTime         @default(now())
  week_day        String[]
  courses         Course           @relation(fields: [course_id], references: [id])
  rooms           Room             @relation(fields: [room_id], references: [id])
  GroupTeacher    GroupTeacher[]
  homework        Homework[]
  lessons         Lesson[]
  studentGroups   StudentGroup[]
  attendances     Attendance[]
  homeworkResults HomeworkResult[]
}

model StudentGroup {
  id         Int      @id @default(autoincrement())
  student_id Int
  group_id   Int
  status     Status   @default(active)
  created_at DateTime @default(now())
  update_at  DateTime @default(now())
  groups     Group    @relation(fields: [group_id], references: [id])
  students   Student  @relation(fields: [student_id], references: [id], onDelete: SetNull)

  @@unique([student_id, group_id])
}

model Lesson {
  id          Int        @id @default(autoincrement())
  group_id    Int
  teacher_id  Int?
  user_id     Int?
  topic       String
  description String?
  status      Status     @default(active)
  created_at  DateTime   @default(now())
  update_at   DateTime   @updatedAt
  homework    Homework[]
  groups      Group      @relation(fields: [group_id], references: [id])
  teachers    Teacher?   @relation(fields: [teacher_id], references: [id])
  users       User?      @relation(fields: [user_id], references: [id])
}

model Attendance {
  id         Int      @id @default(autoincrement())
  teacher_id Int?
  user_id    Int?
  group_id   Int
  student_id Int
  isPresent  Boolean
  created_at DateTime @default(now())
  update_at  DateTime @updatedAt
  groups     Group    @relation(fields: [group_id], references: [id])
  students   Student  @relation(fields: [student_id], references: [id])
  teachers   Teacher? @relation(fields: [teacher_id], references: [id])
  users      User?    @relation(fields: [user_id], references: [id])
}
 
model Homework {
  id                     Int                     @id @default(autoincrement())
  teacher_id             Int?
  user_id                Int?
  lesson_id              Int
  group_id               Int
  title                  String
  file                   String?
  created_at             DateTime                @default(now())
  update_at              DateTime                @updatedAt
  groups                 Group                   @relation(fields: [group_id], references: [id])
  lesson                 Lesson                  @relation(fields: [lesson_id], references: [id])
  teachers               Teacher?                @relation(fields: [teacher_id], references: [id])
  users                  User?                   @relation(fields: [user_id], references: [id])
  homeworkAnswerStudents HomeworkAnswerStudent[]
  homeworkResults        HomeworkResult[]
}

model HomeworkAnswerStudent { 
  id              Int              @id @default(autoincrement())
  student_id      Int 
  homework_id     Int
  title           String
  file            String?
  homeworkStatus  HomeworkStatus   @default(PENDING)
  created_at      DateTime         @default(now())
  update_at       DateTime         @updatedAt
  homework        Homework         @relation(fields: [homework_id], references: [id])
  students        Student          @relation(fields: [student_id], references: [id])
  homeworkResults HomeworkResult[]
} 

model HomeworkResult {
  id                    Int                   @id @default(autoincrement())
  homework_answer_id    Int
  teacher_id            Int?
  user_id               Int?
  group_id              Int
  homework_id           Int
  grade                 Int   
  title                 String
  homeworkStatus        HomeworkStatus
  created_at            DateTime              @default(now())
  update_at             DateTime              @updatedAt
  homeworkAnswerStudent HomeworkAnswerStudent @relation(fields: [homework_answer_id], references: [id])
  teachers              Teacher?              @relation(fields: [teacher_id], references: [id])
  users                 User?                 @relation(fields: [user_id], references: [id])
  groups                Group                 @relation(fields: [group_id], references: [id])
  homework              Homework              @relation(fields: [homework_id], references: [id])

  @@unique([homework_answer_id, teacher_id, user_id, group_id, homework_id])
}

model GroupTeacher {
  id         Int      @id @default(autoincrement())
  group_id   Int
  teacher_id Int
  createdAt  DateTime @default(now())
  Group      Group    @relation(fields: [group_id], references: [id])
  Teacher    Teacher  @relation(fields: [teacher_id], references: [id])

  @@unique([group_id, teacher_id])
}

enum Role {
  SUPERADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum CourseLevel {
  beginner
  intermediate
  advanced
}

enum StudentStatus {
  active
  inactive
  freeze
  graduated
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Status {
  active
  inactive
  freeze
}

enum GroupStatus {
  planned
  active
  completed
}
